# Cloudflare Pages response headers (consumed at deploy; never served itself).
#
# Pages' default for assets is `max-age=0, must-revalidate`, which means every
# repeat visit re-validates EVERY sample file. The manifest runs to hundreds of
# files, so that default costs a few hundred round trips (~50s) on a second load
# even though nothing changed. Sample media is immutable at a given path — a
# re-seed writes new dated session folders (new URLs) — so cache it hard.
/samples/*
  Cache-Control: public, max-age=31536000, immutable

# ...except the manifest, which is the index NAMING those files: it must be
# allowed to change so a future re-seed is picked up. (samples.js already
# requests it with cache:'no-store'; this keeps the CDN honest too.)
/samples/manifest.json
  Cache-Control: public, max-age=60, must-revalidate
